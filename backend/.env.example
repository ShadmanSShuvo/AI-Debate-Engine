# AI Debate Engine - Backend Configuration

# Choose your database. Defaults to local SQLite (debate.db) if left blank.
# For PostgreSQL, use: postgresql://username:password@host:port/database
# DATABASE_URL=sqlite:///debate.db

# LLM Providers - Set at least one of these to activate AI features.
# If both are empty, the engine automatically runs in Offline/Mock mode.
OPENAI_API_KEY=
GEMINI_API_KEY=
